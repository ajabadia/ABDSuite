# Ignorar todo por defecto (satélites con sus propios repositorios)
/*

# Permitir explícitamente rastrear los archivos de orquestación y scripts
!/package.json
!/pnpm-workspace.yaml
!/pnpm-lock.yaml
!/turbo.json
!/.env.shared
!/.gitignore
!/scripts/
!/scripts/**
!/utilidades/
!/utilidades/**
!/ABD-Suite-DOCS/
!/ABD-Suite-DOCS/**

# EXCLUSIONES DE SEGURIDAD (Nunca trackear secretos ni resultados locales)
/secretos/
/test-results/
/ABD-Suite-DOCS/secretos/
.env.local
.env.*.local

# Exclusiones de node modules y caché local
node_modules/
.turbo/
.next/
dist/
*.log

# Turborepo
.turbo
