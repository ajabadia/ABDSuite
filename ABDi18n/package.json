{
  "name": "@ajabadia/i18n",
  "version": "1.0.54",
  "type": "module",
  "description": "Centralized i18n messages and routing for ABD Suite",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ajabadia/ABDSuite.git"
  },
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./routing": {
      "types": "./dist/routing.d.ts",
      "import": "./dist/routing.js",
      "require": "./dist/routing.cjs"
    },
    "./navigation": {
      "types": "./dist/navigation.d.ts",
      "import": "./dist/navigation.js",
      "require": "./dist/navigation.cjs"
    },
    "./request": {
      "types": "./dist/request.d.ts",
      "import": "./dist/request.js",
      "require": "./dist/request.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "prebuild": "tsx scripts/compile-locales.ts",
    "build": "tsup",
    "prepare": "pnpm build",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true});require('fs').rmSync('src/locales/es.json',{force:true});require('fs').rmSync('src/locales/en.json',{force:true})\"",
    "lint:i18n": "tsx scripts/compile-locales.ts --lint"
  },
  "dependencies": {
    "next-intl": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "next": "catalog:",
    "next-intl": "catalog:",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "catalog:"
  }
}
