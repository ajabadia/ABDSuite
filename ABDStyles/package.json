{
  "name": "@ajabadia/styles",
  "version": "1.0.113",
  "type": "module",
  "description": "Industrial multi-tenant dynamic styling engine and common visual assets for ABD suite.",
  "main": "dist/index.js",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ajabadia/ABDStyles.git"
  },
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./api/theme": {
      "types": "./dist/api/theme.d.ts",
      "import": "./dist/api/theme.js"
    },
    "./dist/styles/*": "./dist/styles/*"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && node -e \"fs.cpSync('src/styles','dist/styles',{recursive:true})\"",
    "clean": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\"",
    "prepare": "pnpm build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "audit": "powershell ./scripts/abd-audit.ps1"
  },
  "keywords": [
    "abd",
    "theme",
    "multi-tenant",
    "branding",
    "tailwind",
    "yiq"
  ],
  "author": "ABD Team",
  "license": "UNLICENSED",
  "dependencies": {
    "clsx": "catalog:",
    "tailwind-merge": "catalog:",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:",
    "lucide-react": "catalog:",
    "next-intl": "catalog:"
  },
  "peerDependenciesMeta": {
    "@ajabadia/satellite-sdk": {
      "optional": true
    },
    "mongoose": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ajabadia/satellite-sdk": "^1.0.0",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "lucide-react": "catalog:",
    "mongoose": "catalog:",
    "next-intl": "catalog:",
    "react": "catalog:",
    "tsup": "^8.3.5",
    "typescript": "catalog:",
    "vite": "^6.0.0",
    "vitest": "catalog:"
  }
}
