# 🏭 ABDSuite — Environment Variables Template
# Copy this file to .env.shared and fill in your values.

# ── Auth Provider (JWT & Session Encryption) ──
AUTH_JWT_SECRET=change-me-to-a-random-secret
AUTH_SECRET=change-me-to-a-random-secret

# ── ABAC / S2S Central Guardian Secret ──
ABD_INTERNAL_SECRET=change-me-to-a-random-secret

# ── Logging Service Configuration ──
LOGS_SERVICE_URL=http://localhost:5003/api/logs
LOGS_SECRET_TOKEN=change-me

# ── Production Cross-Domain Configuration ──
COOKIE_DOMAIN=.abdia.es
NEXT_PUBLIC_ROOT_DOMAIN=abdia.es

# ── Satellite S2S URLs (GDPR Orchestration) ──
QUIZ_SERVICE_URL=http://localhost:5020
FILES_SERVICE_URL=http://localhost:5005

# ── Field-Level Encryption (AES-256-CBC) ──
ENCRYPTION_SECRET=change-me-to-a-random-secret

# ── Storage Provider ──
# Options: cloudinary | s3Compatible
DEFAULT_STORAGE_PROVIDER=cloudinary

# ── Upstash Redis Session Cache ──
# UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token
