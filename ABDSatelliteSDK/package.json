{
  "name": "@ajabadia/satellite-sdk",
  "version": "1.0.99",
  "description": "Centralized SDK for ABD Ecosystem Satellites: Federated Identity, Tenant Access, and Branding.",
  "main": "./dist/index.mjs",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ajabadia/ABDSatelliteSDK.git"
  },
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "full-audit": "powershell -File ./scripts/abd-audit.ps1"
  },
  "dependencies": {
    "@upstash/redis": "^1.38.0",
    "cloudinary": "^2.5.1",
    "fast-json-stable-stringify": "2.1.0",
    "jose": "6.2.3",
    "mongoose": "9.7.3",
    "zod": "4.4.3"
  },
  "peerDependencies": {
    "@ajabadia/styles": "^1.0.0",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@ajabadia/styles": "^1.0.99",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "lucide-react": "catalog:",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tsup": "^8.0.0",
    "typescript": "catalog:",
    "vite": "^6.0.0",
    "vitest": "catalog:"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./core": {
      "types": "./dist/core.d.mts",
      "import": "./dist/core.mjs"
    },
    "./db": {
      "types": "./dist/db.d.mts",
      "import": "./dist/db.mjs"
    },
    "./logger": {
      "types": "./dist/logger.d.mts",
      "import": "./dist/logger.mjs"
    },
    "./event-bus": {
      "types": "./dist/event-bus.d.mts",
      "import": "./dist/event-bus.mjs"
    },
    "./auth-middleware": {
      "types": "./dist/auth-middleware.d.mts",
      "import": "./dist/auth-middleware.mjs"
    },
    "./utils": {
      "types": "./dist/utils.d.mts",
      "import": "./dist/utils.mjs"
    },
    "./styles": {
      "types": "./dist/styles.d.mts",
      "import": "./dist/styles.mjs"
    },
    "./client": {
      "types": "./dist/client.d.mts",
      "import": "./dist/client.mjs"
    },
    "./contracts": {
      "types": "./dist/contracts.d.mts",
      "import": "./dist/contracts.mjs"
    }
  },
  "keywords": [
    "abd",
    "sso",
    "multi-tenant",
    "satellite",
    "nextjs"
  ],
  "author": "Antigravity | ABD Ecosystem Architecture Team",
  "license": "UNLICENSED"
}
