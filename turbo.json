{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "MONGODB_URI",
    "MONGODB_AUTH_DB",
    "MONGODB_DATA_DB",
    "MONGODB_LOGS_URI",
    "MONGODB_LOGS_DB",
    "AUTH_SECRET",
    "AUTH_URL",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "NEXT_PUBLIC_APP_URL",
    "NEXT_PUBLIC_BASE_URL",
    "COOKIE_DOMAIN",
    "UPSTASH_REDIS_REST_URL",
    "UPSTASH_REDIS_REST_TOKEN",
    "ABD_INTERNAL_SECRET",
    "QUIZ_SERVICE_URL",
    "FILES_SERVICE_URL",
    "DEFAULT_STORAGE_PROVIDER",
    "LOGS_SERVICE_URL",
    "LOGS_SECRET_TOKEN",
    "RESEND_API_KEY",
    "RESEND_FROM_EMAIL",
    "JWT_SECRET",
    "AUTH_JWT_SECRET",
    "MICROSOFT_TENANT_ID",
    "AUTH_CLIENT_ID",
    "AUTH_CLIENT_SECRET"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
