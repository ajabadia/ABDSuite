{
  "name": "abd-suite-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Central orchestrator workspace for the ABDSuite industrial ecosystem.",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "sync-env": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/sync-env.ps1",
    "sync-i18n": "node ./scripts/sync-i18n.mjs",
    "typecheck": "turbo run typecheck",
    "full-audit": "node ./scripts/audit-all.mjs",
    "lint:i18n": "pnpm --filter @ajabadia/i18n lint:i18n"
  },
  "devDependencies": {
    "turbo": "^2.9.16"
  },
  "pnpm": {
    "overrides": {
      "sharp": "0.35.2"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "argon2",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  },
  "packageManager": "pnpm@10.25.0",
  "dependencies": {
    "bcryptjs": "^3.0.3"
  }
}
