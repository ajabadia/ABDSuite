{
    "name":  "abd-files",
    "version":  "0.1.0",
    "private":  true,
    "scripts":  {
                    "dev":  "next dev -p 5005 --webpack",
                    "postinstall":  "node scripts/copy-pandoc-wasm.mjs",
                    "prebuild":  "node ./scripts/clean-quiz.js",
                    "build":  "next build --webpack",
                    "start":  "next start -p 5005",
                    "lint":  "eslint",
                    "typecheck":  "tsc --noEmit",
                    "full-audit":  "powershell -File ./scripts/abd-audit.ps1",
                    "test":  "vitest run",
                    "test:coverage":  "vitest run --coverage",
                    "test:e2e":  "powershell -ExecutionPolicy Bypass -File scripts/run-e2e.ps1",
                    "pandoc:check":  "node scripts/check-pandoc-version.mjs",
                    "pandoc:convert":  "curl -s -X POST 'http://localhost:5005/api/v1/documents/ASSET_ID/convert' -H 'Content-Type: application/json' -d '{\"to\":\"html\"}'"
                },
    "dependencies":  {
