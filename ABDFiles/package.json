                         "tesseract.js":  "^7.0.0",
                         "@aws-sdk/s3-request-presigner":  "^3.1062.0",
                         "@huggingface/transformers":  "^3.8.1",
                         "lucide-react":  "^1.22.0",
                         "kokoro-js":  "1.2.1",
                         "sharp":  "^0.35.2",
                         "googleapis":  "^173.0.0",
                         "@ajabadia/styles":  "^1.0.93",
