{
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm run build",
  "outputDirectory": ".next",
  "headers": [
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "x-vercel-skew-protection",
          "value": "1"
        }
      ]
    }
  ]
}
